# Example .env file - replace values with your own
# Firebase - Web
WEB_API_KEY=YOUR_WEB_API_KEY
WEB_APP_ID=YOUR_WEB_APP_ID
WEB_MESSAGING_SENDER_ID=YOUR_WEB_MESSAGING_SENDER_ID
WEB_PROJECT_ID=YOUR_PROJECT_ID
WEB_AUTH_DOMAIN=YOUR_AUTH_DOMAIN
WEB_STORAGE_BUCKET=YOUR_STORAGE_BUCKET
WEB_MEASUREMENT_ID=YOUR_MEASUREMENT_ID

# Firebase - Android
ANDROID_API_KEY=YOUR_ANDROID_API_KEY
ANDROID_APP_ID=YOUR_ANDROID_APP_ID
ANDROID_MESSAGING_SENDER_ID=YOUR_ANDROID_MESSAGING_SENDER_ID
ANDROID_PROJECT_ID=YOUR_PROJECT_ID
ANDROID_STORAGE_BUCKET=YOUR_STORAGE_BUCKET

# Firebase - Windows
WINDOWS_API_KEY=YOUR_WINDOWS_API_KEY
WINDOWS_APP_ID=YOUR_WINDOWS_APP_ID
WINDOWS_MESSAGING_SENDER_ID=YOUR_WINDOWS_MESSAGING_SENDER_ID
WINDOWS_PROJECT_ID=YOUR_PROJECT_ID
WINDOWS_AUTH_DOMAIN=YOUR_AUTH_DOMAIN
WINDOWS_STORAGE_BUCKET=YOUR_STORAGE_BUCKET
WINDOWS_MEASUREMENT_ID=YOUR_MEASUREMENT_ID
